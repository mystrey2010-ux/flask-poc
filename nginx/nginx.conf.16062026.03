# 1. HTTP to HTTPS Redirect
server {
    listen 80;
    server_name mw-nexus.duckdns.org;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

# 2. Secure HTTPS Server
server {
    listen 443 ssl;
    server_name mw-nexus.duckdns.org;

    ssl_certificate /etc/letsencrypt/live/mw-nexus.duckdns.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/mw-nexus.duckdns.org/privkey.pem;

    # Enforce ultra-modern TLS versions only
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    # HARDENED CIPHERS: Stripped of all old CBC/WEAK suites
    ssl_ciphers 'ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-ECDSA-AES128-GCM-SHA256';

    # OPTIMIZATION: Session caching for faster handshakes
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    # HSTS HEADER: Forces browsers to ONLY use HTTPS for the next year (Triggers A+)
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Additional Security Headers
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;

    client_max_body_size 10M;

    location / {
        proxy_pass http://flask_app:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_connect_timeout 90s;
        proxy_read_timeout 90s;
    }
}
